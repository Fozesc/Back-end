from app import app, db from app.models import Client EXCEL_FILE = "clientes.xls"  # ou clientes.xlsx SHEET_NAME = "CLIENTES"
def parse_percent(value):
    if pd.isna(value):
        return 0.0
    return float(
        str(value)
        .replace('%', '')
        .replace(',', '.')
        .strip()
    )

def parse_money(value):
    if pd.isna(value):
        return 0.0
    return float(
        str(value)
        .replace('.', '')
        .replace(',', '.')
        .strip()
    )

def parse_document(value):
    if pd.isna(value):
        return None
    return str(value).strip()

def import_clients():
    df = pd.read_excel(EXCEL_FILE, sheet_name=SHEET_NAME)

    with app.app_context():
        for _, row in df.iterrows():

            name = str(row['CLIENTES']).strip()

            if not name or name.lower() == 'nan':
                continue

            client = Client.query.filter_by(name=name).first()

            if not client:
                client = Client(name=name)
                db.session.add(client)

            client.standard_rate = parse_percent(row.get('TAXA'))
            client.document = parse_document(row.get('CPF / CNPJ'))
            client.credit_limit = parse_money(row.get('LIMITE R$'))

        db.session.commit()
        print("✅ Clientes importados com sucesso!")

if __name__ == "__main__":
    import_clients()

